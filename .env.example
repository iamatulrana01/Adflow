# LLM providers (optional — mock works without keys)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
USE_MOCK_LLM=true
LLM_PROVIDER=openai

# Auth
JWT_SECRET=change-me-in-production
ADMIN_EMAIL=admin@adflow.local
ADMIN_PASSWORD=admin123
REQUIRE_AUTH=false

# Alerts (optional)
SLACK_WEBHOOK_URL=
ALERT_EMAIL_TO=

# AWS (production)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=adflow-campaigns

# Performance
BULK_CONCURRENCY=10
